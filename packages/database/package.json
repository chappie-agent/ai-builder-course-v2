    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "25.3.5",
    "@types/pg": "^8.11.10",
    "dotenv": "^16.5.0",
    "prisma": "7.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
